!$LIB_BASE?="https://raw.githubusercontent.com/sidneydemoraes/libs-plantuml/main"
!include $LIB_BASE/common.puml

!global $EVENT_BG_COLOR?="Orange"
!global $COMMAND_BG_COLOR?="MediumTurquoise"

!procedure Event($id, $name="")
  Card($id, Rectangle, Event, $name)
!endprocedure

skinparam rectangle<<Event>> {
  BackgroundColor $EVENT_BG_COLOR
  FontColor $FONT_COLOR
}
